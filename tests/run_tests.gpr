-- run_tests.gpr
-- GPR project file for the test suite

project Run_Tests is

   for Source_Dirs use ("tests", ".");
   for Object_Dir use "tests/obj";
   for Main use ("run_tests.adb");

   package Compiler is
      for Switches ("Ada") use ("-gnat2012", "-O2", "-gnatwa");
   end Compiler;

end Run_Tests;
